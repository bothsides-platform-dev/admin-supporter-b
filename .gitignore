# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
# Isolated build dir for the e2e webServer (NEXT_DIST_DIR in playwright.config.ts)
# — lets `pnpm e2e` boot a second `next dev` alongside a local `pnpm dev` on :3000
# without colliding on Next 16's `<distDir>/dev/lock`.
/.next-e2e/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright artifacts (Step 14)
/test-results
/playwright-report
/playwright/.cache

# drizzle: keep migrations + meta committed (history + snapshots).

# Sentry Config File
.env.sentry-build-plugin

# Local agent/skill tool state (per-machine, never source)
/.claude/scheduled_tasks.lock
/.serena/memories/
/.superpowers/

# Visual brainstorm companion (superpowers)
.superpowers/
.gstack/

# git worktrees
.worktrees/
